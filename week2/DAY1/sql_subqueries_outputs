**Query #1**

    -- Subquery Questions
    
    -- 1. Find employees who earn more than average salary
    select emp_id,name,salary
    from Employees
    where salary > (select avg(salary) from Employees);

| emp_id | name    | salary |
| ------ | ------- | ------ |
| 1      | Alice   | 60000  |
| 3      | Charlie | 70000  |

