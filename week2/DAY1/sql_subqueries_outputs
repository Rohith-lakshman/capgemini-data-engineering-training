**Query #3**

    -- 
    
    -- 3. Get employees whose salary is equal to the minimum salary
    select emp_id,name,salary
    from Employees
    where salary = (select min(salary) from Employees);

| emp_id | name  | salary |
| ------ | ----- | ------ |
| 4      | David | 40000  |

