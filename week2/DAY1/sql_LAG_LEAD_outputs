**Query #1**

    -- 1: Previous Order Amount (LAG)
    SELECT 
        customer_id,
        order_date,
        amount,
        LAG(amount,1,amount) OVER (
            PARTITION BY customer_id 
            ORDER BY order_date
        ) AS prev_amount
    FROM sales;

